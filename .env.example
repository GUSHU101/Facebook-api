# Internal Node.js port. Do not expose it directly to the public internet.
PORT=3000
DATABASE_URL=postgres://capi_user:replace_password@127.0.0.1:5432/capi_saas
REDIS_URL=redis://127.0.0.1:6379

FB_API_VERSION=v24.0
AES_SECRET_KEY=replace_with_a_32_plus_character_random_secret

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_strong_password

# Optional production tuning
CORS_ORIGIN=*
TRUST_PROXY_HOPS=1
JSON_LIMIT=1mb
BATCH_SIZE=1000
QUEUE_ATTEMPTS=5
QUEUE_BACKOFF_MS=5000
PIXEL_RATE_LIMIT_PER_MINUTE=200
ADMIN_RATE_LIMIT_PER_WINDOW=100
FB_REQUEST_TIMEOUT_MS=15000
FACEBOOK_BATCH_SIZE=100
WORKER_CONCURRENCY=20
WORKER_RATE_LIMIT_MAX=100
WORKER_RATE_LIMIT_DURATION_MS=1000
PURCHASE_SETTLE_MS=8000
STALE_PENDING_MINUTES=10
